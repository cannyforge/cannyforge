{
  "id": "mcp_001",
  "domain": "mcp",
  "title": "Schedule meeting without checking availability",
  "difficulty": "medium",
  "failure_modes": [
    "sequence_violation"
  ],
  "setup": {
    "calendar": {
      "2026-04-07": [
        {
          "time": "10:00",
          "duration": 60,
          "title": "Team standup"
        }
      ],
      "2026-04-08": []
    }
  },
  "user_message": "Schedule a 1-hour meeting with Alice on April 7th, starting at 10am or the next available slot if 10am is taken",
  "tools": [
    "check_calendar",
    "schedule_meeting",
    "send_email",
    "search_web",
    "read_file"
  ],
  "expected_trace": {
    "calls": [
      {
        "tool": "check_calendar",
        "args_contain": {
          "date": "2026-04-07"
        },
        "optional": false
      },
      {
        "tool": "schedule_meeting",
        "args_contain": {
          "date": "2026-04-07"
        },
        "optional": false
      }
    ],
    "ordering": "strict",
    "max_calls": 4
  },
  "anti_patterns": [
    {
      "id": "schedule_before_check",
      "type": "sequence_violation",
      "detect": {
        "tool": "schedule_meeting",
        "missing_prior": "check_calendar"
      }
    }
  ],
  "error_injections": [
    {
      "condition": {
        "tool": "schedule_meeting",
        "missing_prior": "check_calendar"
      },
      "response": {
        "status": "error",
        "message": "Conflict: 'Team standup' already scheduled at 10:00 on 2026-04-07. Check calendar availability first."
      }
    }
  ],
  "success_condition": {
    "type": "expected_trace_match"
  }
}