{
  "id": "data_004",
  "domain": "data",
  "title": "Wrong data source for economic indicator",
  "difficulty": "medium",
  "failure_modes": [
    "wrong_tool"
  ],
  "setup": {
    "databases": {
      "economic": {
        "MORTGAGE30US": {
          "2024-01-04": 6.62,
          "2024-06-06": 6.99,
          "2024-12-26": 6.85
        }
      },
      "market": {
        "SPY": {
          "2024-01-02": 472.3,
          "2024-12-31": 589.7
        }
      }
    }
  },
  "user_message": "Fetch the latest 30-year fixed mortgage rate (series MORTGAGE30US) from the economic database and report the most recent value.",
  "tools": [
    "fetch_economic_data",
    "fetch_market_data",
    "query_db",
    "create_chart",
    "validate_data"
  ],
  "expected_trace": {
    "calls": [
      {
        "tool": "fetch_economic_data",
        "args_contain": {
          "series_id": "MORTGAGE"
        },
        "optional": false
      }
    ],
    "ordering": "partial",
    "max_calls": 3
  },
  "anti_patterns": [
    {
      "id": "wrong_tool_for_fred",
      "type": "wrong_tool",
      "detect": {
        "tool": "fetch_market_data",
        "args_contain": {
          "symbol": "MORTGAGE"
        }
      }
    }
  ],
  "error_injections": [
    {
      "condition": {
        "tool": "fetch_market_data",
        "call_index": 0
      },
      "response": {
        "status": "error",
        "message": "Symbol 'MORTGAGE30US' not found in market data. MORTGAGE30US is a FRED economic series — use fetch_economic_data(series_id='MORTGAGE30US') instead."
      }
    }
  ],
  "success_condition": {
    "type": "expected_trace_match"
  }
}