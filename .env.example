# CannyForge LLM Provider Configuration
# Copy this file to .env and fill in your API keys.
#
# Set LLM_PROTOCOL to one of: openai | anthropic | gemini | deepseek
# Then uncomment the matching block below.

# ---------------------------------------------------------------------------
# Option 1: OpenAI
# ---------------------------------------------------------------------------
# LLM_PROTOCOL=openai
# OPENAI_API_KEY=sk-...
# MODEL_FAST=gpt-4o-mini
# MODEL_BALANCED=gpt-4o
# MODEL_POWERFUL=gpt-4o

# ---------------------------------------------------------------------------
# Option 2: Anthropic Claude
# ---------------------------------------------------------------------------
# LLM_PROTOCOL=anthropic
# ANTHROPIC_API_KEY=sk-ant-...
# MODEL_FAST=claude-haiku-4-20250514
# MODEL_BALANCED=claude-sonnet-4-20250514
# MODEL_POWERFUL=claude-sonnet-4-20250514

# ---------------------------------------------------------------------------
# Option 3: Google Gemini  (uses GeminiProvider — handles thought_signature)
# ---------------------------------------------------------------------------
# LLM_PROTOCOL=gemini
# GEMINI_API_KEY=AIza...
# LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
# MODEL_FAST=gemini-2.0-flash-lite
# MODEL_BALANCED=gemini-2.0-flash
# MODEL_POWERFUL=gemini-2.0-flash

# ---------------------------------------------------------------------------
# Option 4: DeepSeek
# ---------------------------------------------------------------------------
# LLM_PROTOCOL=openai
# DEEPSEEK_API_KEY=sk-...
# LLM_BASE_URL=https://api.deepseek.com
# MODEL_FAST=deepseek-chat
# MODEL_BALANCED=deepseek-chat
# MODEL_POWERFUL=deepseek-reasoner

# ---------------------------------------------------------------------------
# Option 5: Any OpenAI-compatible endpoint (MiniMax, Together, etc.)
# ---------------------------------------------------------------------------
# LLM_PROTOCOL=openai
# LLM_API_KEY=<your-api-key>
# LLM_BASE_URL=https://<your-endpoint>/v1
# MODEL_FAST=<model-name>
# MODEL_BALANCED=<model-name>
# MODEL_POWERFUL=<model-name>
